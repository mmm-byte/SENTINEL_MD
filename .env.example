# ─────────────────────────────────────────────────
# SENTINEL — Environment Configuration Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from Atlas → Connect → Drivers
MONGODB_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# The database SENTINEL will monitor and operate on
MONGODB_DATABASE=sentinel_demo

# Google Cloud project and location (for Vertex AI / Agent Builder)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model to power the agent reasoning
GEMINI_MODEL=gemini-2.0-flash-exp

# Optional: Google API Key if using AI Studio instead of Vertex AI
# GOOGLE_API_KEY=your-api-key
